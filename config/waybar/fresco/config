{
    "ipc": true,
    "position": "bottom",
    "height": 36,
    "margin-bottom": 4,
    "margin-left": 6,
    "margin-right": 6,
    "modules-left": ["sway/workspaces", "sway/mode", "sway/scratchpad"],
    "modules-center": ["sway/window"],
    "modules-right": [
        "custom/swaync", "mpd", "pulseaudio",
        "network", "disk", "custom/gpu",
        "cpu", "memory", "temperature",
        "idle_inhibitor", "tray",
        "custom/weather", "clock"
    ],

    "sway/workspaces": {
        "disable-scroll": false,
        "all-outputs": false,
        "format": "{name}"
    },

    "sway/mode": {
        "format": " {}"
    },

    "sway/scratchpad": {
        "format": "{icon} {count}",
        "show-empty": false,
        "format-icons": ["", ""],
        "tooltip": true,
        "tooltip-format": "{app}: {title}"
    },

    "sway/window": {
        "max-length": 60,
        "rewrite": {
            "(.*) â€” Mozilla Firefox": "  $1",
            "(.*) - Zed": "  $1",
            "foot": " Terminal",
            "btop": " btop",
            "ncmpcpp": "َ°ژ† ncmpcpp"
        }
    },

    "mpd": {
        "format": "َ°ژ†  {title} â€” {artist}  {stateIcon}",
        "format-disconnected": "",
        "format-stopped": "",
        "unknown-tag": "?",
        "interval": 2,
        "state-icons": {
            "paused": "َ°ڈ¤",
            "playing": "َ°گٹ"
        },
        "tooltip-format": "{title}\n{artist} â€” {album}\n[{songPosition}/{queueLength}] {consumeIcon}{randomIcon}{repeatIcon}{singleIcon}",
        "tooltip-format-disconnected": "MPD disconnected",
        "on-click": "mpc toggle",
        "on-click-right": "foot -a ncmpcpp ncmpcpp",
        "on-scroll-up": "mpc volume +2",
        "on-scroll-down": "mpc volume -2",
        "consume-icons": { "on": "َ°†¤ " },
        "random-icons": { "on": "َ°’ں " },
        "repeat-icons": { "on": "َ°‘– " },
        "single-icons": { "on": "َ°‘ک " }
    },

    "idle_inhibitor": {
        "format": "{icon}",
        "format-icons": {
            "activated": "َ°ˆˆ",
            "deactivated": "َ°ˆ‰"
        },
        "tooltip-format-activated": "Idle inhibition ON",
        "tooltip-format-deactivated": "Idle inhibition OFF"
    },

    "tray": {
        "spacing": 8,
        "icon-size": 16
    },

    "clock": {
        "format": "َ°¥” {:%H:%M}",
        "format-alt": "َ°ƒ­ {:%a %d %b}",
        "tooltip-format": "<big>{:%B %Y}</big>\n<tt><small>{calendar}</small></tt>"
    },

    "cpu": {
        "format": "َ°چ› {usage}% {avg_frequency}GHz",
        "interval": 2,
        "tooltip": true,
        "on-click": "foot -a btop btop"
    },

    "memory": {
        "format": "َ°’‹ {used:.1f}G",
        "format-alt": "َ°’‹ {percentage}%",
        "interval": 5,
        "tooltip-format": "RAM: {used:.1f}G / {total:.1f}G\nSwap: {swapUsed:.1f}G / {swapTotal:.1f}G",
        "on-click": "foot -a btop btop"
    },

    "disk": {
        "interval": 30,
        "format": "َ°‹ٹ {percentage_used}%",
        "format-alt": "َ°‹ٹ {free}",
        "path": "/",
        "tooltip-format": "{path}\n{used} / {total} ({percentage_used}%)"
    },

    "temperature": {
        "critical-threshold": 90,
        "format": "َ°”ڈ {temperatureC}آ°",
        "format-critical": "َ°”ڈ {temperatureC}آ°",
        "tooltip": true
    },

    "network": {
        "interval": 2,
        "format-wifi":         "َ°–© â†‘{bandwidthUpBytes} â†“{bandwidthDownBytes}",
        "format-ethernet":     "َ°ˆ€ â†‘{bandwidthUpBytes} â†“{bandwidthDownBytes}",
        "format-linked":       "َ°ˆ€ {ifname}",
        "format-disconnected": "َ°–ھ Disconnected",
        "format-alt":          "َ°–© {essid} َ°’¢ {signalStrength}%",
        "tooltip-format-wifi":     "{essid} َ°’¢ {signalStrength}%\n{ipaddr}/{cidr}\nâ†‘{bandwidthUpBytes} â†“{bandwidthDownBytes}",
        "tooltip-format-ethernet": "{ifname}\n{ipaddr}/{cidr}\nâ†‘{bandwidthUpBytes} â†“{bandwidthDownBytes}",
        "on-click-right": "foot -a nmtui nmtui"
    },

    "pulseaudio": {
        "scroll-step": 5,
        "format": "{icon} {volume}%",
        "format-bluetooth": "َ°‚¯ {icon} {volume}%",
        "format-bluetooth-muted": "َ°‚² َ°–پ",
        "format-muted": "َ°–پ",
        "format-source": "َ°چ¬ {volume}%",
        "format-source-muted": "َ°چ­",
        "format-icons": {
            "headphone": "َ°‹‹",
            "hands-free": "َ°‹ژ",
            "headset": "َ°‹ژ",
            "phone": "َ°ڈ²",
            "portable": "َ°ڈ²",
            "car": "َ°„‹",
            "default": ["َ°•¾", "َ°•؟", "َ°–€"]
        },
        "on-click": "pavucontrol",
        "on-click-right": "foot -a pw-top pw-top",
        "tooltip-format": "{desc}\n{volume}%"
    },

    "custom/gpu": {
        "exec": "waybar-nvidiagpu",
        "exec-if": "which nvidia-smi",
        "return-type": "json",
        "interval": 3,
        "format": "{icon} {text}",
        "format-icons": ["َ°ٹ´", "َ°ٹ´", "َ°ٹ´", "َ°ٹ´", "َ°ٹ´"],
        "tooltip": true,
        "on-click": "foot -a btop btop"
    },

    "custom/swaync": {
        "exec": "swaync-client -swb",
        "exec-if": "which swaync-client",
        "return-type": "json",
        "format": "{icon}",
        "format-icons": {
            "none": "َ°‚ڑ",
            "notification": "َ°‚‍",
            "dnd-none": "َ°‚›",
            "dnd-notification": "َ°‚›"
        },
        "tooltip": true,
        "on-click": "swaync-client -t -sw",
        "on-click-right": "swaync-client -d -sw"
    },

    "custom/weather": {
        "exec": "waybar-weather",
        "exec-if": "which curl",
        "return-type": "json",
        "interval": 1800,
        "format": "{}",
        "tooltip": true
    }
}
