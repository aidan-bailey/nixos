# Sway config — nesco (Zenbook S16 OLED, AMD iGPU)
include ~/.config/sway/common

# Brightness keys (laptop)
bindsym XF86MonBrightnessUp exec brightnessctl set +10%
bindsym XF86MonBrightnessDown exec brightnessctl set 10%-

# Output (Zenbook S16 OLED 2880x1800)
output eDP-1 {
  scale 1.5
  adaptive_sync on
}

# Touchpad
input type:touchpad {
    tap enabled
    tap_button_map lrm
    natural_scroll enabled
    dwt enabled
    middle_emulation enabled
    click_method clickfinger
    scroll_method two_finger
    accel_profile adaptive
    pointer_accel 0.3
}

# VNC
exec wayvnc 0.0.0.0 --config-path ~/.config/wayvnc/config

# Touchpad gestures
bindgesture swipe:right workspace prev
bindgesture swipe:left workspace next
bindgesture swipe:up exec $menu
bindgesture swipe:down exec $term

bar {
    swaybar_command waybar
    position bottom
    mode hide
    hidden_state hide
    modifier Mod4
}
